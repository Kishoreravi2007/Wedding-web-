# ═══════════════════════════════════════════
# Discord Bot Configuration
# ═══════════════════════════════════════════
# Get your bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Your bot's Application ID (from Discord Developer Portal)
CLIENT_ID=your_bot_application_id_here

# OpenAI API key for /ai command (https://platform.openai.com/api-keys)
OPENAI_KEY=your_openai_api_key_here

# Website URL for /status command
WEBSITE_URL=https://your-website.com

# ═══════════════════════════════════════════
# Existing Backend Variables (already in .env)
# ═══════════════════════════════════════════
# NODE_ENV=production
# PORT=5002
# BACKEND_URL=https://your-backend.com
# FRONTEND_URL=https://your-frontend.com
# FIREBASE_PROJECT_ID=your-project-id
