# Firebase Configuration (for wishes only)
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=./wedding-429e4-firebase-adminsdk-fbsvc-1ce2602299.json
FIREBASE_STORAGE_BUCKET=your-firebase-storage-bucket.appspot.com

# Supabase Configuration (for photos and face recognition)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Configuration (for photographer authentication)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Upload Configuration
MAX_FILE_SIZE_MB=10
MAX_FILES_PER_UPLOAD=10

# Face Recognition Configuration
FACE_MATCH_THRESHOLD=0.6
FACE_DESCRIPTOR_DIMENSIONS=128

