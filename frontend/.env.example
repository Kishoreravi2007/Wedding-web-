# Supabase Project URL - Find this in your Supabase project's API settings
VITE_SUPABASE_URL="YOUR_SUPABASE_URL"

# Supabase Project Public API Key (anon key) - Find this in your Supabase project's API settings
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# A secret password to view the wishes page
VITE_WISHES_PASSWORD="your-secret-password"